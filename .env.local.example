# Site URL — used for canonical URLs, sitemap, robots.txt, JSON-LD
# Set to your production domain (e.g. https://site.ruslanfreelance.ru)
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 — Measurement ID (e.g. G-XXXXXXXXXX)
# Get from: https://analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=

# Yandex.Metrika — Counter ID (e.g. 12345678)
# Get from: https://metrika.yandex.ru → Settings → Counter number
NEXT_PUBLIC_YM_ID=

# Telegram Bot Token — for contact form notifications
# Create a bot via @BotFather, then paste the token here
TELEGRAM_BOT_TOKEN=
